generator client {
  provider             = "prisma-client"
  output               = "../src/generated/prisma"
  importFileExtension  = "js"
  moduleFormat         = "esm"
}

datasource db {
  provider = "postgresql"
 }

model Plan {
  id             String   @id @default(uuid()) @db.Uuid
  name           String
  credits        Int
  price          Float
  paddlePriceId  String?  @unique @map("paddle_price_id")
  features       Json     @default("[]")
  popular        Boolean  @default(false)
  active         Boolean  @default(true)
  sortOrder      Int      @default(0) @map("sort_order")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  @@map("plans")
}

model Transaction {
  id                  String   @id @default(uuid()) @db.Uuid
  userId              String   @db.Uuid @map("user_id")
  paddleTransactionId String   @unique @map("paddle_transaction_id")
  amount              Float
  currency            String   @default("USD")
  creditsPurchased    Int      @map("credits_purchased")
  creditsBefore       Float    @map("credits_before")
  creditsAfter        Float    @map("credits_after")
  status              String   @default("completed")
  details             Json?
  createdAt           DateTime @default(now()) @map("created_at")
  updatedAt           DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id])

  @@map("transactions")
}

model PaddleWebhookEvent {
  evtId       String   @id @map("evt_id")
  eventType   String   @map("event_type")
  processedAt DateTime @default(now()) @map("processed_at")

  @@map("paddle_webhook_events")
}

model VerificationCode {
  id           String   @id @default(uuid()) @db.Uuid
  email        String
  code         String
  passwordHash String   @map("password_hash")
  expiresAt    DateTime @map("expires_at")
  used         Boolean  @default(false)
  createdAt    DateTime @default(now()) @map("created_at")

  @@map("verification_codes")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid @map("user_id")
  token     String   @unique
  expiresAt DateTime @map("expires_at")
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])

  @@map("email_verification_tokens")
}

model User {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  passwordHash String @map("password_hash")
  credits   Float    @default(5)
  avatarUrl String?  @map("avatar_url")
  emailNotifications Boolean @default(true) @map("email_notifications")
  marketingEmails Boolean @default(false) @map("marketing_emails")
  isEmailVerified Boolean @default(false) @map("is_email_verified")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")
  deletedAt DateTime? @map("deleted_at")

  jobs                  GenerationJob[]
  emailVerificationTokens EmailVerificationToken[]
  transactions          Transaction[]

  @@map("users")
}

model GenerationJob {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid @map("user_id")
  type        String
  prompt      String
  model       String
  creditsUsed Float    @map("credits_used")
  status      String
  imageUrl    String?  @map("output_url")
  createdAt   DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id])
  preferredHomepageSlots PreferredHomepageGeneration[]

  @@map("generation_jobs")
}

model PreferredHomepageGeneration {
  slot         Int           @id
  generationId String       @unique @db.Uuid @map("generation_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")

  generation GenerationJob @relation(fields: [generationId], references: [id], onDelete: Cascade)

  @@map("preferred_homepage_generations")
}
