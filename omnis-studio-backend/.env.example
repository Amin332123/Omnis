# Database
DATABASE_URL="postgresql://user:password@localhost:5432/db_name?schema=public"

# Fal.ai (Flux & Wan 2.5)
FAL_API_KEY="your_fal_api_key_here"

# OpenAI (GPT Image)
OPENAI_API_KEY="your_openai_api_key_here"
OPENAI_REFERENCE_ANALYSIS_MODEL="gpt-4.1-mini"

# Frontend URL (used in verification email links)
FRONTEND_URL="http://localhost:3000"

# Resend (email verification — HTTPS API, no SMTP needed)
RESEND_API_KEY="re_..."
MAIL_FROM_ADDRESS="noreply@omnis-studio.com"
MAIL_FROM_NAME="Omnis studio"

# CORS (comma-separated)
CORS_ORIGINS="http://localhost:3000,https://your-production-domain.com"

# Application
PORT=4000
JWT_SECRET="change_me_in_production"
